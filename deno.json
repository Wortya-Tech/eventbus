{
  "name": "fanaticjs",
  "version": "1.0.0",
  "license": "GPLv3",
  "exports": "./src/main.ts",
  "description": "RabbitMQ library for Deno implementing independent queues and events using fanout strategy.",
  "compilerOptions": {
    "lib": ["ES2022", "deno.ns"],
    "module": "ESNext",
    "strict": true
  },
  "tasks": {
    "test:unit": "deno test test/unit -A",
    "test:e2e": "docker compose up -d && sleep 15 && deno test test/e2e -A && docker compose down",
    "rabbitmq:start": "docker compose up -d",
    "rabbitmq:stop": "docker compose down",
    "doc": "deno doc --html --name='fanaticjs' ./src/main.ts"
  },
  "publish": {
    "include": ["src", "LICENSE", "README.md"],
    "exclude": ["test"]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1.0.2",
    "amqplib": "npm:amqplib@^0.10.9",
    "pino": "npm:pino@^10.3.1"
  },
  "fmt": {
    "singleQuote": false,
    "lineWidth": 100,
    "exclude": ["./docs"]
  },
  "permissions": {
    "default": {
      "read": [".", "src", "test"],
      "net": ["localhost"],
      "env": ["NODE_V8_COVERAGE"],
      "sys": ["hostname"]
    }
  }
}
